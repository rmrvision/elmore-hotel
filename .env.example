# ───────── El More — переменные окружения ─────────
# Скопируйте в .env и заполните. Файл .env в git НЕ попадает.

# Авторизация админки (bcrypt-хэш — установите через npm run setpass)
ADMIN_PASSWORD_HASH=

# Секрет сессий (любая длинная случайная строка)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Порт и хост
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ───────── Timeweb S3 (продакшен) ─────────
# Если эти три переменные заданы — сервер хранит контент и загрузки в S3.
# Если пустые — используются локальные файлы (для разработки).

S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
